{
  "builds": [
    {"src": "api/*.py", "use": "@vercel/python"},
    {"src": "api/data.json", "use": "@vercel/static"},
    {"src": "**/*.html", "use": "@vercel/static"},
    {"src": "images/*", "use": "@vercel/static"}
  ],
  "routes": [
    {"src": "/api/(.*)", "dest": "/api/search.py"},
    {"src": "/(.*)", "dest": "/$1"}
  ]
}
